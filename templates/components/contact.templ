package components

templ Contact() {
	<section id="contact" class="py-5">
		<div class="container">
			<h2 class="text-center mb-4">Контакты</h2>
			<div class="row justify-content-center">
				<div class="col-md-6">
					<p>Свяжитесь с нами удобным способом:</p>
					<ul class="list-unstyled">
						<li><strong>Телефон:</strong> +7 (000) 000-00-00</li>
						<li><strong>Email:</strong> info@company.ru</li>
					</ul>
				</div>
			</div>
		</div>
	</section>
}