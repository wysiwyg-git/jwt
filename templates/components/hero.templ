package components

templ Hero() {
	<div class="hero-section d-flex align-items-center text-white">
		<div class="container text-center py-5">
			<h1 class="display-3 fw-bold mb-3">Профессиональные решения для бизнеса</h1>
			<p class="lead mb-4">Мы помогаем компаниям расти и достигать целей</p>
			<a href="/contact" class="btn btn-outline-light btn-lg px-5 rounded-pill">Связаться с нами</a>
		</div>
	</div>
}