package components

templ Hero() {
	<div class="hero-section d-flex align-items-center text-white">
		<div class="container text-center py-5">
			<h1 class="display-3 fw-bold mb-3">Промышленные клеи и герметики</h1>
			<p class="lead mb-4">Поставки для производства, строительства и ремонта по всей России</p>
			<a href="/contact" class="btn btn-outline-light btn-lg px-5 rounded-pill">Запросить консультацию</a>
		</div>
	</div>
}